{
    "name": "quillphp/quill",
    "description": "Quill — High-performance PHP 8.3+ API framework. Boot once, serve forever.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "api",
        "framework",
        "micro",
        "rest",
        "openapi",
        "fast"
    ],
    "homepage": "https://quillphp.com",
    "authors": [
        {
            "name": "QuillPHP Team",
            "email": "hello@quillphp.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-ffi": "*",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "quillphp/cache": "^0.0.1",
        "quillphp/container": "^0.0.1",
        "quillphp/eloquent": "^0.0.1",
        "quillphp/quill-core": "^0.0.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^3.8",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11",
        "quillphp/testing": "^0.0.1"
    },
    "autoload": {
        "psr-4": {
            "Quill\\": "src/",
            "Quill\\Attributes\\": "attributes/",
            "Handlers\\": "handlers/",
            "Dtos\\": "dtos/",
            "Domain\\": "domain/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Quill\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/quill"
    ],
    "scripts": {
        "test": "pest tests/",
        "analyze": "phpstan analyse --memory-limit 256M",
        "serve": "bin/quill serve",
        "bench": "bin/quill benchmark"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.3.30"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}