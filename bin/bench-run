#!/usr/bin/env bash
# =============================================================================
# Quill -- Real HTTP Benchmark Runner
# =============================================================================
#
# Two modes:
#
#   HTTP/1.1 (default)  -- PHP built-in server + wrk / ab
#     bash scripts/bench_run.sh
#
#   HTTP/2 production   -- FrankenPHP Docker (worker mode) + h2load
#     DOCKER=1 bash scripts/bench_run.sh
#     (requires: docker, h2load)
#
# Options (env vars):
#   PHP           PHP binary            (default: php)
#   HOST          Server host           (default: 127.0.0.1)
#   PORT          PHP CLI server port   (default: 8765)
#   DOCKER        Set to 1 for FrankenPHP Docker + h2load (default: 0)
#   DOCKER_PORT   Host port for Docker container (default: 8443)
#   DURATION      Seconds per h2load / wrk test (default: 10)
#   CONNECTIONS   Concurrent connections        (default: 100)
#   STREAMS       HTTP/2 streams per conn       (default: 10)
#   THREADS       Worker threads                (default: 4)
#   AB_REQUESTS   Total requests for ab         (default: 50000)
#
# Examples:
#   bash scripts/bench_run.sh
#   PHP=/opt/homebrew/bin/php bash scripts/bench_run.sh
#   DOCKER=1 DURATION=30 CONNECTIONS=200 bash scripts/bench_run.sh
# =============================================================================

set -euo pipefail

# Extend PATH so Homebrew-installed tools are always found
export PATH="/opt/homebrew/opt/nghttp2/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

# -- Config -------------------------------------------------------------------
PHP="${PHP:-php}"
HOST="${HOST:-127.0.0.1}"
PORT="${PORT:-8765}"
DOCKER="${DOCKER:-0}"
SWOOLE="${SWOOLE:-0}"
DOCKER_PORT="${DOCKER_PORT:-8443}"
BENCH_PORT="${BENCH_PORT:-8080}"
SWOOLE_BENCH_PORT="${SWOOLE_BENCH_PORT:-8080}"
DURATION="${DURATION:-10}"
CONNECTIONS="${CONNECTIONS:-100}"
STREAMS="${STREAMS:-10}"
THREADS="${THREADS:-4}"
AB_REQUESTS="${AB_REQUESTS:-50000}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER_SCRIPT="${SCRIPT_DIR}/bench_server.php"
COMPOSE_FILE="${SCRIPT_DIR}/docker-compose.bench.yml"
COMPOSE_SWOOLE="${SCRIPT_DIR}/docker-compose.swoole.yml"
TMP_POST_BODY="$(mktemp /tmp/quill_bench_post.XXXXXX)"
SERVER_PID=""
DOCKER_STARTED=0
SWOOLE_STARTED=0

# Derive BASE_URL based on mode (may be overridden by DOCKER/SWOOLE block below)
BASE_URL="http://${HOST}:${PORT}"
HEALTH_BASE="${BASE_URL}"

# -- Colours ------------------------------------------------------------------
BOLD="\033[1m"
GREEN="\033[0;32m"
CYAN="\033[0;36m"
YELLOW="\033[1;33m"
RESET="\033[0m"

header()  { echo -e "\n${BOLD}${CYAN}$*${RESET}"; }
info()    { echo -e "  ${GREEN}>${RESET} $*"; }
warn()    { echo -e "  ${YELLOW}!${RESET}  $*"; }
divider() { echo "  ---------------------------------------------"; }

# -- Cleanup trap -------------------------------------------------------------
cleanup() {
    rm -f "${TMP_POST_BODY}"
    if [ -n "${SERVER_PID}" ]; then
        kill "${SERVER_PID}" 2>/dev/null || true
    fi
    if [ "${DOCKER_STARTED}" = "1" ]; then
        echo ""
        info "Stopping FrankenPHP container..."
        docker compose -f "${COMPOSE_FILE}" down --remove-orphans >/dev/null 2>&1 || true
    fi
    if [ "${SWOOLE_STARTED}" = "1" ]; then
        echo ""
        info "Stopping Swoole container..."
        docker compose -f "${COMPOSE_SWOOLE}" down --remove-orphans >/dev/null 2>&1 || true
    fi
    echo ""
    info "Done."
    echo ""
}
trap cleanup EXIT

# -- POST body file -----------------------------------------------------------
printf '%s' '{"email":"bench@quill.dev","name":"Quill Bench","role":"admin"}' \
    > "${TMP_POST_BODY}"

# -- Validate prerequisites ---------------------------------------------------
if [ "${SWOOLE}" = "1" ]; then
    if ! command -v docker >/dev/null 2>&1; then
        warn "Docker is required for SWOOLE=1."
        exit 1
    fi
    TOOL="h2load"
    BASE_URL="http://localhost:${SWOOLE_BENCH_PORT}"
    HEALTH_BASE="${BASE_URL}"
    CURL_FLAGS="-sf"
elif [ "${DOCKER}" = "1" ]; then
    if ! command -v docker >/dev/null 2>&1; then
        warn "Docker is required for DOCKER=1. Install from https://docker.com"
        exit 1
    fi
    if ! command -v h2load >/dev/null 2>&1; then
        warn "h2load is required for DOCKER=1. Install: brew install nghttp2"
        exit 1
    fi
    TOOL="h2load"
    # h2load v1.64+ dropped --insecure/-k and always verifies TLS certs.
    # Use HTTP/2 cleartext (h2c) on port 8080 for all benchmark traffic so
    # no certificate trust is required.
    # The HTTPS port (8443 / localhost) is only used for the Docker healthcheck
    # via curl -k inside the container.
    HEALTH_BASE="https://localhost:${DOCKER_PORT}"
    BASE_URL="http://localhost:${BENCH_PORT}"
    CURL_FLAGS="-kfs"    # -k = accept self-signed TLS cert (healthcheck only)
else
    CURL_FLAGS="-sf"
    # HTTP/1.1 tool selection: wrk preferred, ab fallback
    # h2load is NOT used for HTTP/1.1 -- it pipelines requests which the
    # PHP built-in server does not support.
    if command -v wrk >/dev/null 2>&1; then
        TOOL="wrk"
    elif command -v ab >/dev/null 2>&1; then
        TOOL="ab"
    else
        warn "No HTTP/1.1 benchmark tool found."
        warn "  wrk : brew install wrk"
        warn "  ab  : brew install httpd  /  sudo apt install apache2-utils"
        warn ""
        warn "For HTTP/2 (FrankenPHP Docker) use: DOCKER=1 bash scripts/bench_run.sh"
        exit 1
    fi
fi

# -- Resolve PHP binary -------------------------------------------------------
PHP_BIN="$(command -v "${PHP}" 2>/dev/null || echo "${PHP}")"
PHP_VERSION="$("${PHP_BIN}" -r 'echo PHP_VERSION;' 2>/dev/null || echo "n/a")"

# -- Startup info -------------------------------------------------------------
header "Quill Benchmark -- Real HTTP Server"
echo ""
if [ "${SWOOLE}" = "1" ]; then
    info "Mode       : Swoole Docker (NTS PHP + JIT tracing + async HTTP)"
    info "Image      : scripts/Dockerfile.swoole"
    info "Bench URL  : ${BASE_URL}"
elif [ "${DOCKER}" = "1" ]; then
    info "Mode       : FrankenPHP Docker (HTTP/2 worker mode)"
    info "Image      : scripts/Dockerfile.bench"
    info "Bench URL  : ${BASE_URL}  (h2c — HTTP/2 cleartext, no cert needed)"
    info "Health URL : ${HEALTH_BASE}  (HTTPS, self-signed, curl -k)"
else
    info "Mode       : PHP built-in server (HTTP/1.1)"
    info "PHP binary : ${PHP_VERSION}"
    info "Server     : ${BASE_URL}"
fi
info "Tool       : ${TOOL}"
info "Duration   : ${DURATION}s per test"
info "Connections: ${CONNECTIONS}"
if [ "${TOOL}" = "h2load" ]; then
    info "Streams    : ${STREAMS}  (HTTP/2 concurrent streams per connection)"
fi
if [ "${TOOL}" != "ab" ]; then
    info "Threads    : ${THREADS}"
fi
divider

# -- Start server -------------------------------------------------------------
if [ "${SWOOLE}" = "1" ]; then
    info "Building Swoole image (first build ~90s — compiles Swoole extension)..."
    docker compose -f "${COMPOSE_SWOOLE}" build 2>&1 \
        | grep -E "^(#|=>|DONE|ERROR|Successfully)" | sed 's/^/    /' || true
    info "Starting Swoole container..."
    docker compose -f "${COMPOSE_SWOOLE}" up -d >/dev/null 2>&1
    SWOOLE_STARTED=1
elif [ "${DOCKER}" = "1" ]; then
    info "Building FrankenPHP image (first build may take ~60s)..."
    docker compose -f "${COMPOSE_FILE}" build 2>&1 \
        | grep -E "^(#|=>|DONE|ERROR|Successfully)" | sed 's/^/    /' || true
    info "Starting container..."
    docker compose -f "${COMPOSE_FILE}" up -d >/dev/null 2>&1
    DOCKER_STARTED=1
else
    # PHP_CLI_SERVER_WORKERS enables multiple worker processes (PHP 8.0+)
    info "Starting PHP built-in server on ${HOST}:${PORT} (${THREADS} workers)..."
    PHP_CLI_SERVER_WORKERS="${THREADS}" \
        "${PHP_BIN}" -S "${HOST}:${PORT}" "${SERVER_SCRIPT}" >/dev/null 2>&1 &
    SERVER_PID=$!
fi

# -- Wait for readiness -------------------------------------------------------
READY=0
HEALTH_URL="${HEALTH_BASE}/health"
for _ in $(seq 1 80); do
    # shellcheck disable=SC2086
    if curl ${CURL_FLAGS} "${HEALTH_URL}" >/dev/null 2>&1; then
        READY=1
        break
    fi
    sleep 0.5
done

if [ "${READY}" -eq 0 ]; then
    if [ "${DOCKER}" = "1" ]; then
        warn "Container did not become healthy within 40s."
        warn "Check logs: docker compose -f scripts/docker-compose.bench.yml logs"
    elif [ "${SWOOLE}" = "1" ]; then
        warn "Swoole container did not become healthy within 40s."
        warn "Check logs: docker compose -f scripts/docker-compose.swoole.yml logs"
    else
        warn "Server did not start within 40s. Check for port conflicts on :${PORT}."
    fi
    exit 1
fi
info "Server is ready"

# -- Warmup -------------------------------------------------------------------
info "Warming up (500 requests)..."
for _ in $(seq 1 500); do
    # shellcheck disable=SC2086
    curl ${CURL_FLAGS} "${BASE_URL}/hello" >/dev/null
done
info "Warmup complete"
echo ""

# =============================================================================
# Test helpers
# =============================================================================

run_h2load() {
    local label="$1"; shift
    echo -e "${BOLD}  > ${label}${RESET}"
    # SWOOLE=1 uses HTTP/1.1 (no TLS); DOCKER=1 uses HTTP/2 cleartext (h2c).
    local extra_flags=""
    if [ "${SWOOLE:-0}" = "1" ]; then
        extra_flags="--h1"   # force HTTP/1.1 — Swoole listens on plain TCP
    fi
    h2load \
        -c "${CONNECTIONS}" \
        -t "${THREADS}" \
        -m "${STREAMS}" \
        -D "${DURATION}" \
        ${extra_flags} \
        "$@" 2>&1 \
        | grep -E "(req/s|requests:|status codes:|time for request|finished in)" \
        | sed 's/^/    /'
    echo ""
}

run_wrk() {
    local label="$1"; shift
    echo -e "${BOLD}  > ${label}${RESET}"
    wrk -t"${THREADS}" -c"${CONNECTIONS}" -d"${DURATION}s" "$@" 2>&1 | sed 's/^/    /'
    echo ""
}

run_ab() {
    local label="$1"; shift
    echo -e "${BOLD}  > ${label}${RESET}"
    ab -n "${AB_REQUESTS}" -c "${CONNECTIONS}" -q "$@" 2>&1 \
        | grep -E "^(Requests per second|Time per request|Transfer rate|Complete requests|Failed|Non-2xx)" \
        | sed 's/^/    /'
    echo ""
}

# =============================================================================
# Benchmark suite
# =============================================================================
header "Benchmark Results"
echo ""

LUA_POST="${SCRIPT_DIR}/bench_post.lua"

if [ "${TOOL}" = "h2load" ]; then

    run_h2load "GET /hello  (simple JSON, no I/O)" \
        "${BASE_URL}/hello"

    run_h2load "GET /users/42  (path param)" \
        "${BASE_URL}/users/42"

    run_h2load "POST /echo  (JSON decode + encode)" \
        -d "${TMP_POST_BODY}" \
        -H "Content-Type: application/json" \
        "${BASE_URL}/echo"

elif [ "${TOOL}" = "wrk" ]; then

    run_wrk "GET /hello  (simple JSON, no I/O)" \
        "${BASE_URL}/hello"

    run_wrk "GET /users/42  (path param)" \
        "${BASE_URL}/users/42"

    if [ -f "${LUA_POST}" ]; then
        run_wrk "POST /echo  (JSON decode + encode)" \
            -s "${LUA_POST}" "${BASE_URL}/echo"
    else
        run_wrk "POST /echo  (no Lua script -- GET /hello used as stand-in)" \
            "${BASE_URL}/hello"
    fi

else  # ab

    run_ab "GET /hello  (simple JSON, no I/O)" \
        "${BASE_URL}/hello"

    run_ab "GET /users/42  (path param)" \
        "${BASE_URL}/users/42"

    run_ab "POST /echo  (JSON decode + encode)" \
        -p "${TMP_POST_BODY}" \
        -T "application/json" \
        "${BASE_URL}/echo"

fi

# =============================================================================
divider
if [ "${SWOOLE}" = "1" ]; then
    info "Swoole NTS PHP + JIT tracing + HTTP/1.1 — maximum PHP throughput."
    info "For even higher numbers on Linux: increase SWOOLE_WORKERS to match vCPU count."
elif [ "${DOCKER}" = "1" ]; then
    info "FrankenPHP worker mode + HTTP/2 -- production-grade result."
else
    info "PHP built-in server, HTTP/1.1. For prod-grade numbers:"
    info "  DOCKER=1 bash ${SCRIPT_DIR}/bench_run.sh   (FrankenPHP HTTP/2)"
    info "  SWOOLE=1 bash ${SCRIPT_DIR}/bench_run.sh   (Swoole NTS+JIT HTTP/1.1)"
fi
echo ""

